# ── Core AI + Retrieval ─────────────────────────────────────────────
# Google Generative Language / Gemini-compatible key used for report and brief writing
GOOGLE_API_KEY=your-google-api-key
AI_MODEL=gemini-1.5-pro

# YouTube Data API key for video discovery
YOUTUBE_API_KEY=your-youtube-api-key

# Tavily key for live web search
TAVILY_API_KEY=your-tavily-api-key

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
RESEARCH_BOT_OUTPUT_DIR=./papers
TESTING_MODE=true
MAX_REQUESTS_PER_HOUR=3

# ── Optional Telegram Mode ──────────────────────────────────────────
# Leave blank if you only want to use the WhatsApp bridge endpoints.
TELEGRAM_BOT_TOKEN=
WEBHOOK_URL=

# ── Optional Admin / Legacy Integrations ────────────────────────────
ADMIN_API_KEY=professor-ai-admin-2026
PAYSTACK_SECRET_KEY=
SUPABASE_URL=
SUPABASE_KEY=
